&lt;table&gt;
 &lt;thead&gt;
 &lt;tr&gt;
 &lt;th&gt;首字母&lt;/th&gt;
 &lt;th&gt;可见性&lt;/th&gt;
 &lt;th&gt;示例&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;大写&lt;/td&gt;
